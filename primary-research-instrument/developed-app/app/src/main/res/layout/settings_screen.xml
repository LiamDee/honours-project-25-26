<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="50sp">
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="40dp"
            android:text="Settings">
        </TextView>
    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="30sp"
        android:layout_gravity="center">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:textSize="18dp"
            android:text="Text about composing email with stats">
        </TextView>
    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:layout_height="wrap_content"
        android:paddingTop="10sp">
        <Button
            android:background="@drawable/buttonshape"
            android:textSize="20dp"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:id="@+id/emailBtn"
            android:text="Compose Email"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="30sp"
        android:layout_gravity="center">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:textSize="18dp"
            android:text="Text about disabling reminders">
        </TextView>
    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:layout_height="wrap_content"
        android:paddingTop="10sp">
        <Button
            android:background="@drawable/buttonshape"
            android:textSize="20dp"
            android:layout_width="230dp"
            android:layout_height="60dp"
            android:id="@+id/disableReminderBtn"
            android:text="Disable Reminders"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="30sp"
        android:layout_gravity="center">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:textSize="18dp"
            android:text="Text about editing goal">
        </TextView>
    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:layout_height="wrap_content"
        android:paddingTop="10sp"
        android:layout_weight="1">
        <Button
            android:background="@drawable/buttonshape"
            android:textSize="20sp"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:id="@+id/editGoalBtn"
            android:text="Edit Goal"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:layout_height="wrap_content"
        android:paddingBottom="60sp">
        <Button
            android:background="@drawable/buttonshape"
            android:textSize="20sp"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:id="@+id/backToMainBtn"
            android:text="Back"/>
    </LinearLayout>

</LinearLayout>